# =============================================================================
# OpenFMR Admin UI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# PostgreSQL connection string for the Client Registry staging database.
# This database holds demographic conflict records awaiting steward resolution.
CR_STAGING_DB_URL=postgresql://cr_user:cr_pass@cr-staging-db:5432/cr_staging

# PostgreSQL connection string for the Health Facility Registry staging database.
# This database holds facility conflict records awaiting steward resolution.
HFR_STAGING_DB_URL=postgresql://hfr_user:hfr_pass@hfr-staging-db:5432/hfr_staging

# PostgreSQL connection string for the Health Worker Registry staging database.
# This database holds practitioner conflict records awaiting steward resolution.
HWR_STAGING_DB_URL=postgresql://hwr_user:hwr_pass@hwr-staging-db:5432/hwr_staging

# PostgreSQL connection string for the LMIS staging database.
# This database holds supply chain conflict records awaiting steward resolution.
LMIS_STAGING_DB_URL=postgresql://lmis_user:lmis_pass@lmis-staging-postgres:5432/lmis_staging
